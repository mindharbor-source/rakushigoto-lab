---
import { articles } from '../data/articles';
const { currentPath, category } = Astro.props;
const base = import.meta.env.BASE_URL;
const related = articles
  .filter((article) => article.path !== currentPath)
  .sort((a, b) => Number(b.category === category) - Number(a.category === category))
  .slice(0, 3);
---
{related.length > 0 && (
  <aside class="related-articles" aria-labelledby="related-articles-title">
    <h2 id="related-articles-title">次に読みたい記事</h2>
    <div class="related-grid">
      {related.map((article) => (
        <article class="related-card">
          <span class="badge">{article.category}</span>
          <h3><a href={`${base}articles/${article.path}`}>{article.title}</a></h3>
          <p>{article.summary}</p>
        </article>
      ))}
    </div>
    <a class="back-to-index" href={`${base}articles/`}>すべての記事を見る <span aria-hidden="true">→</span></a>
  </aside>
)}
