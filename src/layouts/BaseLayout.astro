---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
const {
  title,
  description = '非エンジニアの会社員向けに、AI・業務効率化・在宅勤務の実践情報をわかりやすく届けます。',
  type = 'website',
  published,
  updated,
  noindex = false
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const structuredData = type === 'article' ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title.replace(/ \| ラクシゴト研究所$/, ''),
  description,
  datePublished: published,
  dateModified: updated ?? published,
  mainEntityOfPage: canonicalURL.href,
  author: { '@type': 'Organization', name: 'ラクシゴト研究所 編集部' },
  publisher: { '@type': 'Organization', name: 'ラクシゴト研究所' }
} : null;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500
      });

      const consentKey = 'rakushigoto-consent-v1';
      const loadAnalytics = () => {
        if (document.querySelector('script[data-rakushigoto-ga]')) return;
        gtag('consent', 'update', { analytics_storage: 'granted' });
        const tag = document.createElement('script');
        tag.async = true;
        tag.src = 'https://www.googletagmanager.com/gtag/js?id=G-KFS7H4J39Y';
        tag.dataset.rakushigotoGa = 'true';
        document.head.appendChild(tag);
        gtag('config', 'G-KFS7H4J39Y', { allow_google_signals: false });
      };

      const saveConsent = (choice) => {
        localStorage.setItem(consentKey, choice);
        document.getElementById('cookie-consent')?.setAttribute('hidden', '');
        if (choice === 'analytics') loadAnalytics();
        else gtag('consent', 'update', { analytics_storage: 'denied' });
      };

      const trackLinkClick = (link) => {
        if (localStorage.getItem(consentKey) !== 'analytics') return;

        const destination = new URL(link.href, window.location.href);
        const linkText = (link.textContent || '').replace(/\s+/g, ' ').trim().slice(0, 100);
        const commonParameters = {
          link_url: destination.href,
          link_text: linkText,
          source_path: window.location.pathname
        };

        if (destination.hostname === 'af.moshimo.com') {
          gtag('event', 'affiliate_click', {
            ...commonParameters,
            affiliate_network: 'moshimo',
            merchant: 'rakuten'
          });
          return;
        }

        if (
          destination.origin === window.location.origin &&
          destination.pathname.includes('/articles/') &&
          destination.pathname !== window.location.pathname
        ) {
          gtag('event', 'article_click', commonParameters);
        }
      };

      document.addEventListener('DOMContentLoaded', () => {
        const banner = document.getElementById('cookie-consent');
        const saved = localStorage.getItem(consentKey);
        if (saved === 'analytics') loadAnalytics();
        else if (!saved) banner?.removeAttribute('hidden');

        document.getElementById('consent-accept')?.addEventListener('click', () => saveConsent('analytics'));
        document.getElementById('consent-reject')?.addEventListener('click', () => saveConsent('necessary'));
        document.querySelectorAll('[data-open-cookie-settings]').forEach((button) => {
          button.addEventListener('click', () => banner?.removeAttribute('hidden'));
        });
        document.addEventListener('click', (event) => {
          const link = event.target instanceof Element ? event.target.closest('a') : null;
          if (link) trackLinkClick(link);
        });
      });
    </script>
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="ラクシゴト研究所" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {published && <meta property="article:published_time" content={published} />}
    {updated && <meta property="article:modified_time" content={updated} />}
    {structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
    <aside id="cookie-consent" class="cookie-consent" aria-labelledby="cookie-consent-title" hidden>
      <div>
        <strong id="cookie-consent-title">アクセス解析Cookieについて</strong>
        <p>サイト改善のため、同意いただいた場合のみGoogle Analyticsを使用します。拒否してもサイトを利用できます。詳しくは<a href={`${import.meta.env.BASE_URL}privacy/`}>プライバシーポリシー</a>をご覧ください。</p>
      </div>
      <div class="cookie-actions">
        <button id="consent-reject" class="button secondary" type="button">すべて拒否</button>
        <button id="consent-accept" class="button" type="button">分析を許可</button>
      </div>
    </aside>
  </body>
</html>
