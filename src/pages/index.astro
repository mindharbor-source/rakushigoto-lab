---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const articles = [
  ['AI文字起こしの精度を上げる7つの方法','articles/improve-ai-transcription-accuracy/','AI仕事術','誤変換を減らす録音・マイク・話し方のチェックリスト。'],
  ['AI文字起こしの精度を上げたい人向けWeb会議用マイク3選','articles/web-meeting-microphones-for-ai-transcription/','在宅勤務','AI議事録で聞き取りやすい音声を残すための3機種を比較。'],
  ['会社で生成AIを安全に使うための基本チェックリスト','articles/generative-ai-security/','AI仕事術','入力前に確認したい情報管理と社内ルールを整理。'],
  ['AI議事録ツールを選ぶ7つの基準','articles/ai-meeting-tool-guide/','AIツール比較','料金だけでは分からない比較ポイントを解説。'],
  ['文字起こしサービスの選び方','articles/transcription-service-guide/','業務効率化','精度・話者分離・保存条件から選ぶ方法。'],
  ['在宅勤務のインターネット回線を選ぶ基準','articles/remote-work-internet-guide/','在宅勤務','会議やVPNで困らない回線選びの考え方。'],
  ['光回線とホームルーターの違い','articles/fiber-vs-home-router/','在宅勤務','速度、工事、解約まで含めて比較。'],
  ['会社員向け生成AIツールの選び方','articles/business-ai-tool-guide/','AIツール比較','用途・セキュリティ・費用から候補を絞る。']
];
---
<BaseLayout title="ラクシゴト研究所 | AI・業務効率化・在宅勤務の実践メディア" description="非エンジニアの会社員向けに、生成AI、業務効率化サービス、在宅勤務環境の選び方と実践方法を届けます。">
  <section class="hero container">
    <span class="badge">非エンジニア会社員向け</span>
    <h1>仕事を、少しラクに。<br />選ぶ前に、判断基準を。</h1>
    <p class="lead">AIツール、業務サービス、在宅勤務環境について、広告だけに左右されない比較軸と導入手順を整理する実践メディアです。</p>
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:28px">
      <a class="button" href={`${base}articles/`}>記事を読む</a>
      <a class="button secondary" href={`${base}about/`}>編集方針を見る</a>
    </div>
  </section>

  <section class="section container">
    <div class="section-head"><div><span class="eyebrow">What we cover</span><h2>このサイトが提供するもの</h2></div></div>
    <div class="grid">
      <div class="card feature-card"><h3>AI仕事術</h3><p>営業・事務・管理職が、専門知識なしで試せる活用方法を解説します。</p></div>
      <div class="card feature-card"><h3>比較の判断基準</h3><p>料金だけでなく、セキュリティ、解約条件、導入負荷まで整理します。</p></div>
      <div class="card feature-card"><h3>在宅勤務環境</h3><p>回線、PC、周辺機器を「仕事で困らない」観点から選びます。</p></div>
    </div>
  </section>

  <section class="section container">
    <div class="section-head"><div><span class="eyebrow">Latest guides</span><h2>新着記事</h2></div><a href={`${base}articles/`}>すべての記事を見る →</a></div>
    <div class="grid article-list">
      {articles.map(([title,path,category,summary]) => <article class="card"><span class="badge">{category}</span><h3><a href={`${base}${path}`}>{title}</a></h3><p>{summary}</p><span class="meta">約5〜8分で読めます</span></article>)}
    </div>
  </section>

  <section class="section container">
    <div class="cta-panel"><div><h2 style="margin:0">迷ったら、まず判断基準から。</h2><p>ランキングではなく、選ぶための軸を先に確認できます。</p></div><a class="button" href={`${base}articles/`}>ガイドを確認する</a></div>
  </section>
</BaseLayout>
